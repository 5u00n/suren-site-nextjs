# Optional: GitHub personal access token for higher API rate limits and contribution data.
# Without it: 60 req/hr for REST; no contribution calendar on About page.
# Create at https://github.com/settings/tokens — enable "read:user" for contribution calendar.
# GITHUB_TOKEN=

# Visitor tracking settings
# Production/live: uses Upstash Redis (required).
# Localhost/development: falls back to data/visitors.json.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=               # supported alias
# KV_REST_API_TOKEN=             # supported alias

# Required in production: only this domain can access /api/visitors.
# VISITOR_ALLOWED_DOMAIN=your-domain.com

# Optional: salt used to hash visitor fingerprints before storing.
# VISITOR_HASH_SALT=replace-with-a-random-secret
